{
  "name": "mod-version-inspector",
  "version": "1.0.0",
  "description": "Desktop app to inspect Java mod jars and estimate Java and game versions.",
  "main": "main.js",
  "scripts": {
    "start": "node ./scripts/start-electron.js",
    "test": "node --test tests/*.test.js",
    "build": "electron-builder",
    "dist": "electron-builder --win nsis"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.pint.modversioninspector",
    "productName": "Mod Version Inspector",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scripts/start-electron.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
